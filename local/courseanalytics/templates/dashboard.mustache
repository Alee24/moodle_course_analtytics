<div class="local_courseanalytics_dashboard container-fluid py-3">

    {{! ===== HEADER ===== }}
    <div class="d-flex justify-content-between align-items-center mb-5 pb-3 border-bottom flex-wrap gap-2">
        <h1 class="ca-page-title d-flex align-items-center m-0" style="font-size: 2.2rem; color: #1e3a5f;">
            <i class="fa fa-bar-chart mr-3" style="color: #1e3a5f;"></i>
            <span class="font-weight-bold">Manage Course Analytics</span>
        </h1>
        <div>
            <a href="{{urls.export}}" class="btn btn-success shadow-sm px-4 py-2 font-weight-bold" style="background-color: #6a9c47; border-color: #6a9c47; border-radius: 8px;">
                <i class="fa fa-file-excel-o mr-2"></i> Export to Excel
            </a>
        </div>
    </div>

    {{! ===== FILTER ===== }}
    <div class="card ca-card mb-4 border-0 shadow-sm" style="border-radius: 12px; background: #fff;">
        <div class="card-body p-4">
            <form action="{{urls.index}}" method="get" class="form-inline d-flex flex-wrap gap-3 align-items-center">
                <div class="form-group mr-3 mb-2">
                    <label class="mr-2 font-weight-bold text-dark">Filter by Category:</label>
                    <select name="category" class="custom-select shadow-sm" style="border-radius: 6px;">
                        <option value="" {{#require_category}}selected{{/require_category}}>-- All Categories --</option>
                        {{#categories}}
                            <option value="{{id}}" {{#selected}}selected{{/selected}}>{{name}}</option>
                        {{/categories}}
                    </select>
                </div>
                
                <div class="form-group mr-3 mb-2">
                    <label class="mr-2 font-weight-bold text-dark">Course Shortcode:</label>
                    <input type="text" name="coursecode" value="{{filters.coursecode}}" placeholder="e.g. COMP101" class="form-control shadow-sm" style="border-radius: 6px;">
                </div>

                <div class="form-group mr-3 mb-2">
                    <label class="mr-2 font-weight-bold text-dark">Lecturer Email:</label>
                    <input type="email" name="lectureremail" value="{{filters.lectureremail}}" placeholder="e.g. jdoe@university.edu" class="form-control shadow-sm" style="border-radius: 6px;">
                </div>

                <div class="form-group mb-2 ml-auto">
                    <button type="submit" class="btn text-white font-weight-bold shadow-sm px-4" style="background-color: #c00085; border-radius: 8px;">
                        <i class="fa fa-filter mr-1"></i> Apply Filters
                    </button>
                    <a href="{{urls.index}}" class="btn btn-outline-secondary ml-2 shadow-sm font-weight-bold" style="border-radius: 8px;">
                        <i class="fa fa-refresh"></i> Clear
                    </a>
                </div>
            </form>
        </div>
    </div>

    {{#require_category}}
    <div class="alert alert-info text-center py-5 shadow-sm ca-card border-0" style="background-color: #e0f2f1; border-radius: 12px;">
        <i class="fa fa-info-circle fa-4x mb-3 text-info opacity-75" style="color: #00897b !important;"></i>
        <h3 class="font-weight-bold text-dark">Welcome to Course Analytics</h3>
        <p class="lead mb-0 text-secondary">Please select a category or enter a search filter above to load course statistics.</p>
    </div>
    {{/require_category}}

    {{^require_category}}
    {{! ===== SUMMARY CARDS ===== }}
    <div class="row mb-5 justify-content-center">
        <div class="col-md-3 mb-4">
            <div class="card ca-stat-card border-0 text-white text-center h-100" style="background-color: #1e3a5f; box-shadow: 0 10px 20px rgba(0,0,0,0.1); border-radius: 12px;">
                <div class="card-body d-flex flex-column justify-content-center p-4 py-5">
                    <div class="ca-stat-icon mb-3"><i class="fa fa-book" style="font-size: 2.5rem; opacity: 0.9;"></i></div>
                    <div class="ca-stat-value font-weight-bold" style="font-size: 3.2rem; line-height: 1;">{{total_courses}}</div>
                    <div class="ca-stat-label mt-2 text-uppercase font-weight-bold" style="font-size: 0.85rem; letter-spacing: 1px;">COURSES</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="card ca-stat-card border-0 text-white text-center h-100" style="background-color: #27ae60; box-shadow: 0 10px 20px rgba(0,0,0,0.1); border-radius: 12px;">
                <div class="card-body d-flex flex-column justify-content-center p-4 py-5">
                    <div class="ca-stat-icon mb-3"><i class="fa fa-users" style="font-size: 2.5rem; opacity: 0.9;"></i></div>
                    <div class="ca-stat-value font-weight-bold" style="font-size: 3.2rem; line-height: 1;">{{charts.participation.active}}</div>
                    <div class="ca-stat-label mt-2 text-uppercase font-weight-bold" style="font-size: 0.85rem; letter-spacing: 1px;">ACTIVE STUDENTS (7 DAYS)</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="card ca-stat-card border-0 text-white text-center h-100" style="background-color: #e67e22; box-shadow: 0 10px 20px rgba(0,0,0,0.1); border-radius: 12px;">
                <div class="card-body d-flex flex-column justify-content-center p-4 py-5">
                    <div class="ca-stat-icon mb-3"><i class="fa fa-user-times" style="font-size: 2.5rem; opacity: 0.9;"></i></div>
                    <div class="ca-stat-value font-weight-bold" style="font-size: 3.2rem; line-height: 1;">{{charts.participation.inactive}}</div>
                    <div class="ca-stat-label mt-2 text-uppercase font-weight-bold" style="font-size: 0.85rem; letter-spacing: 1px;">INACTIVE STUDENTS</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="card ca-stat-card border-0 text-white text-center h-100" style="background-color: #00bcd4; box-shadow: 0 10px 20px rgba(0,0,0,0.1); border-radius: 12px;">
                <div class="card-body d-flex flex-column justify-content-center p-4 py-5">
                    <div class="ca-stat-icon mb-3"><i class="fa fa-pie-chart" style="font-size: 2.5rem; opacity: 0.9;"></i></div>
                    <div class="ca-stat-value font-weight-bold" style="font-size: 2.5rem; line-height: 1; padding: 11px 0;">
                        {{#charts.participation.active}}
                            {{#charts.participation.inactive}} — {{/charts.participation.inactive}}
                        {{/charts.participation.active}}
                        {{^charts.participation.active}}—{{/charts.participation.active}}
                    </div>
                    <div class="ca-stat-label mt-2 text-uppercase font-weight-bold" style="font-size: 0.85rem; letter-spacing: 1px;">PARTICIPATION OVERVIEW</div>
                </div>
            </div>
        </div>
    </div>

    {{! ===== CHARTS ===== }}
    <div class="row mb-5">
        <div class="col-md-4 mb-4 mb-md-0">
            <div class="card ca-card border-0 h-100" style="border-radius: 12px; box-shadow: 0 8px 25px rgba(0,0,0,0.03); background: #fdfdfd;">
                <div class="card-header border-bottom-0 bg-transparent pt-4 pb-2 text-center">
                    <h5 class="font-weight-bold text-muted mb-0 mx-auto" style="color: #cbd5e1 !important; font-size: 0.95rem; text-transform: uppercase;">Student Participation</h5>
                </div>
                <div class="card-body d-flex align-items-center justify-content-center p-4">
                    <canvas id="participationChart" style="max-height:260px;"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card ca-card border-0 h-100" style="border-radius: 12px; box-shadow: 0 8px 25px rgba(0,0,0,0.03); background: #fdfdfd;">
                <div class="card-header border-bottom-0 bg-transparent pt-4 pb-2 text-center">
                    <h5 class="font-weight-bold text-muted mb-0 mx-auto" style="color: #cbd5e1 !important; font-size: 0.95rem; text-transform: uppercase;">Completion Rate by Course</h5>
                </div>
                <div class="card-body p-4">
                    <canvas id="engagementChart" style="max-height:260px;"></canvas>
                </div>
            </div>
        </div>
    </div>

    {{! ===== MAIN TABLE ===== }}
    <div class="card ca-card border-0 mb-5" style="border-radius: 12px; box-shadow: 0 8px 25px rgba(0,0,0,0.03);">
        <div class="card-header border-bottom py-4 bg-transparent d-flex justify-content-between align-items-center" style="background: #fdfdfd;">
            <h5 class="font-weight-bold text-muted mb-0 mx-auto" style="color: #e2e8f0 !important;"><i class="fa fa-table mr-2" style="color: #cbd5e1 !important;"></i>Course Statistics ({{total_courses}} courses)</h5>
            <a href="{{urls.export}}" class="btn btn-sm btn-outline-success font-weight-bold px-3 shadow-sm mx-auto" style="border-radius: 6px;">
                <i class="fa fa-download mr-1"></i> Download Excel
            </a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered table-hover ca-table mb-0 text-nowrap">
                    <thead style="background-color: #f8f9fa;">
                        <tr>
                            <th rowspan="2" class="align-middle text-muted text-uppercase bg-transparent" style="font-size: 0.75rem; letter-spacing: 0.5px; border-bottom: none;">#</th>
                            <th rowspan="2" class="align-middle text-muted text-uppercase bg-transparent" style="font-size: 0.75rem; letter-spacing: 0.5px; border-bottom: none;">Course Name</th>
                            <th rowspan="2" class="align-middle text-muted text-uppercase bg-transparent" style="font-size: 0.75rem; letter-spacing: 0.5px; border-bottom: none;">Category</th>
                            <th colspan="3" class="text-center text-muted text-uppercase bg-transparent" style="font-size: 0.75rem; letter-spacing: 0.5px; border-bottom: 2px solid #e9ecef;">Lecturer</th>
                            <th colspan="4" class="text-center text-muted text-uppercase bg-transparent" style="font-size: 0.75rem; letter-spacing: 0.5px; border-bottom: 2px solid #e9ecef;">Students</th>
                            <th colspan="8" class="text-center text-muted text-uppercase bg-transparent" style="font-size: 0.75rem; letter-spacing: 0.5px; border-bottom: 2px solid #e9ecef;">Course Content</th>
                            <th rowspan="2" class="align-middle text-center text-muted text-uppercase bg-transparent" style="font-size: 0.75rem; letter-spacing: 0.5px; border-bottom: none;">Actions</th>
                        </tr>
                        <tr>
                            <th class="text-muted text-uppercase bg-transparent" style="font-size: 0.7rem; border-top: none;">Name</th>
                            <th class="text-muted text-uppercase bg-transparent" style="font-size: 0.7rem; border-top: none;">Email</th>
                            <th class="text-muted text-uppercase bg-transparent" style="font-size: 0.7rem; border-top: none;">Last Login</th>
                            <th class="text-muted text-uppercase bg-transparent" style="font-size: 0.7rem; border-top: none;">Total</th>
                            <th class="text-muted text-uppercase bg-transparent" style="font-size: 0.7rem; border-top: none;">Active (7d)</th>
                            <th class="text-muted text-uppercase bg-transparent" style="font-size: 0.7rem; border-top: none;">Inactive</th>
                            <th class="text-muted text-uppercase bg-transparent" style="font-size: 0.7rem; border-top: none;">Completion %</th>
                            <th class="text-muted text-uppercase bg-transparent" style="font-size: 0.7rem; border-top: none;"><i class="fa fa-play-circle" title="H5P Interactive"></i> H5P</th>
                            <th class="text-muted text-uppercase bg-transparent" style="font-size: 0.7rem; border-top: none;"><i class="fa fa-tasks" title="Assignments"></i> Assign</th>
                            <th class="text-muted text-uppercase bg-transparent" style="font-size: 0.7rem; border-top: none;"><i class="fa fa-question-circle" title="Quizzes"></i> Quiz</th>
                            <th class="text-muted text-uppercase bg-transparent" style="font-size: 0.7rem; border-top: none;"><i class="fa fa-comments" title="Forums"></i> Forum</th>
                            <th class="text-muted text-uppercase bg-transparent" style="font-size: 0.7rem; border-top: none;"><i class="fa fa-file" title="Files"></i> Files</th>
                            <th class="text-muted text-uppercase bg-transparent" style="font-size: 0.7rem; border-top: none;"><i class="fa fa-video-camera" title="Videos"></i> Videos</th>
                            <th class="text-muted text-uppercase bg-transparent" style="font-size: 0.7rem; border-top: none;"><i class="fa fa-link" title="URLs"></i> URLs</th>
                            <th class="text-muted text-uppercase bg-transparent" style="font-size: 0.7rem; border-top: none;">Total Res.</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#courses}}
                        <tr>
                            <td class="text-center text-muted small">{{@index}}</td>
                            <td><a href="{{url}}" class="ca-course-link">{{fullname}}</a></td>
                            <td><span class="badge badge-secondary">{{categoryname}}</span></td>
                            <td class="small align-middle">
                                {{#lecturers}}
                                    <div class="ca-multi-item">{{name}}</div>
                                {{/lecturers}}
                                {{^lecturers}}<span class="text-muted">-</span>{{/lecturers}}
                            </td>
                            <td class="small align-middle">
                                {{#lecturers}}
                                    <div class="ca-multi-item"><a href="mailto:{{email}}">{{email}}</a></div>
                                {{/lecturers}}
                                {{^lecturers}}<span class="text-muted">-</span>{{/lecturers}}
                            </td>
                            <td class="small ca-lastaccess align-middle">
                                {{#lecturers}}
                                    <div class="ca-multi-item">{{lastaccess}}</div>
                                {{/lecturers}}
                                {{^lecturers}}<span class="text-muted">-</span>{{/lecturers}}
                            </td>
                            <td class="text-center"><span class="badge badge-info">{{total_students}}</span></td>
                            <td class="text-center"><span class="badge badge-success">{{active_students}}</span></td>
                            <td class="text-center"><span class="badge badge-warning">{{inactive_students}}</span></td>
                            <td class="text-center">
                                <span class="ca-pct-badge">{{completion_rate}}%</span>
                            </td>
                            <td class="text-center font-weight-bold text-info">{{h5p}}</td>
                            <td class="text-center">{{assignments}}</td>
                            <td class="text-center">{{quizzes}}</td>
                            <td class="text-center">{{forums}}</td>
                            <td class="text-center">{{files}}</td>
                            <td class="text-center">{{videos}}</td>
                            <td class="text-center">{{urls}}</td>
                            <td class="text-center"><strong>{{total_modules}}</strong></td>
                            <td class="text-center">
                                <a href="{{url}}" class="btn btn-sm btn-primary ca-btn-detail">
                                    <i class="fa fa-eye mr-1"></i> Details
                                </a>
                            </td>
                        </tr>
                        {{/courses}}
                        {{^has_courses}}
                        <tr>
                            <td colspan="19" class="text-center py-4 text-muted">
                                <i class="fa fa-inbox fa-2x mb-2"></i><br>No courses found.
                            </td>
                        </tr>
                        {{/has_courses}}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    {{/require_category}}

    {{! ===== FOOTER ===== }}
    <footer class="text-center text-muted mt-3 py-3 border-top small">
        {{{footer_text}}}
    </footer>
</div>

{{#js}}
require(['core/chartjs'], function(Chart) {

    // Participation Pie Chart
    var ctx1 = document.getElementById('participationChart');
    if (ctx1) {
        new Chart(ctx1.getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: ['Active (7d)', 'Inactive'],
                datasets: [{
                    data: [{{charts.participation.active}}, {{charts.participation.inactive}}],
                    backgroundColor: ['#28a745', '#ffc107'],
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { position: 'bottom' } }
            }
        });
    }

    // Completion Bar Chart
    var ctx2 = document.getElementById('engagementChart');
    if (ctx2) {
        new Chart(ctx2.getContext('2d'), {
            type: 'bar',
            data: {
                labels: [{{#charts.engagement.labels}}'{{.}}',{{/charts.engagement.labels}}],
                datasets: [{
                    label: 'Completion %',
                    data: [{{#charts.engagement.data}}{{.}},{{/charts.engagement.data}}],
                    backgroundColor: 'rgba(0,123,255,0.7)',
                    borderColor: '#007bff',
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                scales: { y: { beginAtZero: true, max: 100 } },
                plugins: { legend: { display: false } }
            }
        });
    }
});
{{/js}}
