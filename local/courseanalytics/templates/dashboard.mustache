<div class="local_courseanalytics_dashboard">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>{{#str}} manageanalytics, local_courseanalytics {{/str}}</h1>
        <div class="actions">
            <button class="btn btn-secondary" onclick="window.print()">{{#str}} export_pdf, local_courseanalytics {{/str}}</button>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <form action="{{urls.index}}" method="get" class="form-inline mb-3">
                <select name="category" class="custom-select mr-2">
                    <option value="0">{{#str}} category, local_courseanalytics {{/str}}</option>
                    {{#categories}}
                        <option value="{{id}}" {{#selected}}selected{{/selected}}>{{name}}</option>
                    {{/categories}}
                </select>
                <button type="submit" class="btn btn-primary">{{#str}} search {{/str}}</button>
            </form>

            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>{{#str}} coursename, local_courseanalytics {{/str}}</th>
                            <th>{{#str}} category, local_courseanalytics {{/str}}</th>
                            <th>{{#str}} students, local_courseanalytics {{/str}}</th>
                            <th>{{#str}} lastaccess, local_courseanalytics {{/str}}</th>
                            <th>{{#str}} actions {{/str}}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#courses}}
                        <tr>
                            <td>{{fullname}}</td>
                            <td>{{categoryname}}</td>
                            <td>{{metrics.total_students}}</td>
                            <td>{{last_access_formatted}}</td>
                            <td>
                                <a href="{{url}}" class="btn btn-sm btn-info">{{#str}} view_details, local_courseanalytics {{/str}}</a>
                            </td>
                        </tr>
                        {{/courses}}
                        {{^courses}}
                        <tr>
                            <td colspan="5" class="text-center">{{#str}} no_courses_found, local_courseanalytics {{/str}}</td>
                        </tr>
                        {{/courses}}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">{{#str}} participation_metrics, local_courseanalytics {{/str}}</div>
                <div class="card-body">
                    <canvas id="participationChart"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">{{#str}} engagement_metrics, local_courseanalytics {{/str}}</div>
                <div class="card-body">
                    <canvas id="engagementChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <footer class="mt-5 text-center text-muted">
        <p>{{{footer_text}}}</p>
    </footer>
</div>

{{#js}}
require(['core/chartjs'], function(Chart) {
    var ctx1 = document.getElementById('participationChart').getContext('2d');
    new Chart(ctx1, {
        type: 'pie',
        data: {
            labels: ['Active', 'Inactive'],
            datasets: [{
                data: [{{charts.participation.active}}, {{charts.participation.inactive}}],
                backgroundColor: ['#28a745', '#dc3545']
            }]
        }
    });

    var ctx2 = document.getElementById('engagementChart').getContext('2d');
    new Chart(ctx2, {
        type: 'bar',
        data: {
            labels: [{{#charts.engagement.labels}}'{{.}}',{{/charts.engagement.labels}}],
            datasets: [{
                label: 'Completion Rate %',
                data: [{{#charts.engagement.data}}{{ . }},{{/charts.engagement.data}}],
                backgroundColor: '#007bff'
            }]
        },
        options: {
            scales: {
                y: {
                    beginAtZero: true,
                    max: 100
                }
            }
        }
    });
});
{{/js}}
