<div class="local_courseanalytics_dashboard container-fluid py-3">

    {{! ===== HEADER ===== }}
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <h1 class="ca-page-title">
            <i class="fa fa-bar-chart mr-2"></i>
            {{#str}} manageanalytics, local_courseanalytics {{/str}}
        </h1>
        <div>
            <a href="{{urls.export}}" class="btn btn-success btn-lg shadow-sm">
                <i class="fa fa-file-excel-o mr-1"></i> Export to Excel
            </a>
        </div>
    </div>

    {{! ===== FILTER ===== }}
    <div class="card ca-card mb-4">
        <div class="card-body p-3">
            <form action="{{urls.index}}" method="get" class="form-inline">
                <label class="mr-2 font-weight-bold">Filter by Category:</label>
                <select name="category" class="custom-select mr-2" required>
                    <option value="" disabled {{#require_category}}selected{{/require_category}}>-- Select a Category --</option>
                    {{#categories}}
                        <option value="{{id}}" {{#selected}}selected{{/selected}}>{{name}}</option>
                    {{/categories}}
                </select>
                <button type="submit" class="btn btn-primary">Load Analytics</button>
            </form>
        </div>
    </div>

    {{#require_category}}
    <div class="alert alert-info text-center py-5 shadow-sm ca-card">
        <i class="fa fa-info-circle fa-4x mb-3 text-info opacity-75"></i>
        <h3 class="font-weight-bold">Welcome to Course Analytics</h3>
        <p class="lead mb-0">Please select a category from the filter above to begin loading course statistics.</p>
    </div>
    {{/require_category}}

    {{^require_category}}
    {{! ===== SUMMARY CARDS ===== }}
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card ca-stat-card bg-gradient-primary text-white text-center">
                <div class="card-body">
                    <div class="ca-stat-icon"><i class="fa fa-book"></i></div>
                    <div class="ca-stat-value">{{total_courses}}</div>
                    <div class="ca-stat-label">Courses</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card ca-stat-card bg-gradient-success text-white text-center">
                <div class="card-body">
                    <div class="ca-stat-icon"><i class="fa fa-users"></i></div>
                    <div class="ca-stat-value">{{charts.participation.active}}</div>
                    <div class="ca-stat-label">Active Students (7 days)</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card ca-stat-card bg-gradient-warning text-white text-center">
                <div class="card-body">
                    <div class="ca-stat-icon"><i class="fa fa-user-times"></i></div>
                    <div class="ca-stat-value">{{charts.participation.inactive}}</div>
                    <div class="ca-stat-label">Inactive Students</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card ca-stat-card bg-gradient-info text-white text-center">
                <div class="card-body">
                    <div class="ca-stat-icon"><i class="fa fa-pie-chart"></i></div>
                    <div class="ca-stat-value">
                        {{#charts.participation.active}}
                            {{#charts.participation.inactive}} — {{/charts.participation.inactive}}
                        {{/charts.participation.active}}
                    </div>
                    <div class="ca-stat-label">Participation Overview</div>
                </div>
            </div>
        </div>
    </div>

    {{! ===== CHARTS ===== }}
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card ca-card h-100">
                <div class="card-header ca-card-header">Student Participation</div>
                <div class="card-body d-flex align-items-center justify-content-center">
                    <canvas id="participationChart" style="max-height:250px;"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card ca-card h-100">
                <div class="card-header ca-card-header">Completion Rate by Course</div>
                <div class="card-body">
                    <canvas id="engagementChart" style="max-height:250px;"></canvas>
                </div>
            </div>
        </div>
    </div>

    {{! ===== MAIN TABLE ===== }}
    <div class="card ca-card mb-4">
        <div class="card-header ca-card-header d-flex justify-content-between align-items-center">
            <span><i class="fa fa-table mr-2"></i>Course Statistics ({{total_courses}} courses)</span>
            <a href="{{urls.export}}" class="btn btn-sm btn-outline-success">
                <i class="fa fa-download mr-1"></i> Download Excel
            </a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered table-hover ca-table mb-0">
                    <thead>
                        <tr class="ca-thead-primary">
                            <th rowspan="2" class="align-middle">#</th>
                            <th rowspan="2" class="align-middle">Course Name</th>
                            <th rowspan="2" class="align-middle">Category</th>
                            <th colspan="3" class="text-center">Lecturer</th>
                            <th colspan="4" class="text-center">Students</th>
                            <th colspan="8" class="text-center">Course Content</th>
                            <th rowspan="2" class="align-middle text-center">Actions</th>
                        </tr>
                        <tr class="ca-thead-secondary">
                            <th>Name</th>
                            <th>Email</th>
                            <th>Last Login</th>
                            <th>Total</th>
                            <th>Active (7d)</th>
                            <th>Inactive</th>
                            <th>Completion %</th>
                            <th><i class="fa fa-play-circle" title="H5P Interactive"></i> H5P</th>
                            <th><i class="fa fa-tasks" title="Assignments"></i> Assign</th>
                            <th><i class="fa fa-question-circle" title="Quizzes"></i> Quiz</th>
                            <th><i class="fa fa-comments" title="Forums"></i> Forum</th>
                            <th><i class="fa fa-file" title="Files"></i> Files</th>
                            <th><i class="fa fa-video-camera" title="Videos"></i> Videos</th>
                            <th><i class="fa fa-link" title="URLs"></i> URLs</th>
                            <th>Total Modules</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#courses}}
                        <tr>
                            <td class="text-center text-muted small">{{@index}}</td>
                            <td><a href="{{url}}" class="ca-course-link">{{fullname}}</a></td>
                            <td><span class="badge badge-secondary">{{categoryname}}</span></td>
                            <td class="small align-middle">
                                {{#lecturers}}
                                    <div class="ca-multi-item">{{name}}</div>
                                {{/lecturers}}
                                {{^lecturers}}<span class="text-muted">-</span>{{/lecturers}}
                            </td>
                            <td class="small align-middle">
                                {{#lecturers}}
                                    <div class="ca-multi-item"><a href="mailto:{{email}}">{{email}}</a></div>
                                {{/lecturers}}
                                {{^lecturers}}<span class="text-muted">-</span>{{/lecturers}}
                            </td>
                            <td class="small ca-lastaccess align-middle">
                                {{#lecturers}}
                                    <div class="ca-multi-item">{{lastaccess}}</div>
                                {{/lecturers}}
                                {{^lecturers}}<span class="text-muted">-</span>{{/lecturers}}
                            </td>
                            <td class="text-center"><span class="badge badge-info">{{total_students}}</span></td>
                            <td class="text-center"><span class="badge badge-success">{{active_students}}</span></td>
                            <td class="text-center"><span class="badge badge-warning">{{inactive_students}}</span></td>
                            <td class="text-center">
                                <span class="ca-pct-badge">{{completion_rate}}%</span>
                            </td>
                            <td class="text-center font-weight-bold text-info">{{h5p}}</td>
                            <td class="text-center">{{assignments}}</td>
                            <td class="text-center">{{quizzes}}</td>
                            <td class="text-center">{{forums}}</td>
                            <td class="text-center">{{files}}</td>
                            <td class="text-center">{{videos}}</td>
                            <td class="text-center">{{urls}}</td>
                            <td class="text-center"><strong>{{total_modules}}</strong></td>
                            <td class="text-center">
                                <a href="{{url}}" class="btn btn-sm btn-primary ca-btn-detail">
                                    <i class="fa fa-eye mr-1"></i> Details
                                </a>
                            </td>
                        </tr>
                        {{/courses}}
                        {{^has_courses}}
                        <tr>
                            <td colspan="19" class="text-center py-4 text-muted">
                                <i class="fa fa-inbox fa-2x mb-2"></i><br>No courses found.
                            </td>
                        </tr>
                        {{/has_courses}}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    {{/require_category}}

    {{! ===== FOOTER ===== }}
    <footer class="text-center text-muted mt-3 py-3 border-top small">
        {{{footer_text}}}
    </footer>
</div>

{{#js}}
require(['core/chartjs'], function(Chart) {

    // Participation Pie Chart
    var ctx1 = document.getElementById('participationChart');
    if (ctx1) {
        new Chart(ctx1.getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: ['Active (7d)', 'Inactive'],
                datasets: [{
                    data: [{{charts.participation.active}}, {{charts.participation.inactive}}],
                    backgroundColor: ['#28a745', '#ffc107'],
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { position: 'bottom' } }
            }
        });
    }

    // Completion Bar Chart
    var ctx2 = document.getElementById('engagementChart');
    if (ctx2) {
        new Chart(ctx2.getContext('2d'), {
            type: 'bar',
            data: {
                labels: [{{#charts.engagement.labels}}'{{.}}',{{/charts.engagement.labels}}],
                datasets: [{
                    label: 'Completion %',
                    data: [{{#charts.engagement.data}}{{.}},{{/charts.engagement.data}}],
                    backgroundColor: 'rgba(0,123,255,0.7)',
                    borderColor: '#007bff',
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                scales: { y: { beginAtZero: true, max: 100 } },
                plugins: { legend: { display: false } }
            }
        });
    }
});
{{/js}}
