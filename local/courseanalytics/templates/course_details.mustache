<div class="local_courseanalytics_details container-fluid py-5 px-md-5">

    {{! ===== HEADER ===== }}
    <div class="d-flex justify-content-between align-items-center mb-5 flex-wrap gap-4 px-2">
        <h1 class="ca-page-title d-flex align-items-center m-0">
            <div class="mr-4 bg-gradient-purple text-white d-flex align-items-center justify-content-center shadow-lg" style="width: 65px; height: 65px; border-radius: 18px;">
                <i class="fa fa-graduation-cap" style="font-size: 1.8rem;"></i>
            </div>
            <div class="d-flex flex-column">
                <span class="ca-page-title">{{course.shortname}}</span>
                <span class="text-muted small font-weight-bold text-uppercase mt-1" style="letter-spacing: 2px; opacity: 0.7;">{{course.fullname}}</span>
            </div>
        </h1>
        <div class="d-flex align-items-center gap-3">
            <a href="{{urls.back}}" class="btn btn-outline-secondary shadow-sm px-4 py-3 font-weight-bold mr-3" style="border-radius: 14px; border-width: 2px; transition: all 0.3s ease;">
                <i class="fa fa-arrow-left mr-2"></i> Back to Dashboard
            </a>
            <a href="{{urls.export}}" class="btn btn-success shadow-lg px-5 py-3 font-weight-bold" style="background: linear-gradient(135deg, #27ae60, #2ecc71); border: none; border-radius: 14px; transition: all 0.3s ease;">
                <i class="fa fa-file-excel-o mr-2"></i> Export Course Data
            </a>
        </div>
    </div>

    {{! ===== SUMMARY STATS CARDS ===== }}
    <div class="ca-stats-container mb-5">
        <div class="row mx-0 g-4">
            <div class="col-md-3 col-lg-2 px-2 mb-3">
                <div class="card ca-stat-card border-0 text-white bg-gradient-primary">
                    <div class="card-body d-flex flex-column justify-content-center align-items-center p-3">
                        <div class="ca-stat-icon"><i class="fa fa-users"></i></div>
                        <div class="ca-stat-value">{{metrics.total_students}}</div>
                        <div class="ca-stat-label">Enrolled</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-lg-2 px-2 mb-3">
                <div class="card ca-stat-card border-0 text-white bg-gradient-success">
                    <div class="card-body d-flex flex-column justify-content-center align-items-center p-3">
                        <div class="ca-stat-icon"><i class="fa fa-bolt"></i></div>
                        <div class="ca-stat-value">{{metrics.active_students}}</div>
                        <div class="ca-stat-label">Active (7d)</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-lg-2 px-2 mb-3">
                <div class="card ca-stat-card border-0 text-white bg-gradient-info">
                    <div class="card-body d-flex flex-column justify-content-center align-items-center p-3">
                        <div class="ca-stat-icon"><i class="fa fa-trophy"></i></div>
                        <div class="ca-stat-value">{{metrics.completion_rate}}%</div>
                        <div class="ca-stat-label">Completion</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-lg-2 px-2 mb-3">
                <div class="card ca-stat-card border-0 text-white bg-gradient-warning">
                    <div class="card-body d-flex flex-column justify-content-center align-items-center p-3">
                        <div class="ca-stat-icon"><i class="fa fa-cubes"></i></div>
                        <div class="ca-stat-value">{{metrics.total_modules}}</div>
                        <div class="ca-stat-label">Activities</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-lg-2 px-2 mb-3">
                <div class="card ca-stat-card border-0 text-white bg-gradient-purple">
                    <div class="card-body d-flex flex-column justify-content-center align-items-center p-3">
                        <div class="ca-stat-icon"><i class="fa fa-clock"></i></div>
                        <div class="ca-stat-value" style="font-size: 1.6rem;">{{metrics.avg_time_spent}}</div>
                        <div class="ca-stat-label">Avg. Time</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-lg-2 px-2 mb-3">
                <div class="card ca-stat-card border-0 text-white bg-gradient-danger">
                    <div class="card-body d-flex flex-column justify-content-center align-items-center p-3">
                        <div class="ca-stat-icon"><i class="fa fa-video"></i></div>
                        <div class="ca-stat-value">{{metrics.bbb}}</div>
                        <div class="ca-stat-label">Virtual</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {{! ===== CHARTS ===== }}
    <div class="row mb-5 justify-content-center px-2">
        <div class="col-lg-5 mb-4">
            <div class="ca-glass-card p-4 h-100">
                <h5 class="font-weight-bold text-center mb-4 p-2 text-uppercase small letter-spacing-1" style="color: #64748b; border-bottom: 2px solid #f1f5f9;">
                    <i class="fa fa-chart-pie mr-2 text-info"></i> User Activity Breakdown
                </h5>
                <div class="d-flex align-items-center justify-content-center" style="height: 300px;">
                    <canvas id="courseParticipationChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    {{! ===== NAVIGATION TABS ===== }}
    <div class="d-flex justify-content-center mb-5">
        <div class="ca-glass-card p-2 d-inline-flex shadow-sm" style="border-radius: 18px;">
            <ul class="nav nav-pills ca-nav-pills border-0" id="courseAnalyticsTabs" role="tablist">
                <li class="nav-item">
                    <a class="nav-link active px-5 py-3 font-weight-bold" id="content-tab" data-toggle="tab" href="#content" role="tab" style="border-radius: 14px; transition: all 0.3s;">
                        <i class="fa fa-project-diagram mr-2"></i> Course Structure Breakdown
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link px-5 py-3 font-weight-bold" id="students-tab" data-toggle="tab" href="#students" role="tab" style="border-radius: 14px; transition: all 0.3s;">
                        <i class="fa fa-user-friends mr-2"></i> Enrolled Student Metrics
                    </a>
                </li>
            </ul>
        </div>
    </div>

    <div class="tab-content" id="courseAnalyticsTabsContent">
        {{! ===== CONTENT TAB ===== }}
        <div class="tab-pane fade show active" id="content" role="tabpanel">
            <div class="row px-2">
                {{#sections}}
                <div class="col-12 mb-5">
                    <div class="ca-table-container">
                        <div class="p-4 bg-light border-bottom d-flex justify-content-between align-items-center">
                            <h5 class="mb-0 font-weight-bold" style="color: var(--ca-primary);">
                                <i class="fa fa-folder-open mr-2 text-purple"></i>{{{name}}}
                            </h5>
                            <span class="badge badge-primary px-3 py-2 rounded-lg" style="background: var(--ca-primary);">{{#is_empty}}Empty Section{{/is_empty}}{{^is_empty}}Active Content{{/is_empty}}</span>
                        </div>
                        <div class="p-0">
                            {{^is_empty}}
                            <div class="table-responsive">
                                <table class="table ca-table table-hover mb-0">
                                    <thead class="ca-thead-primary">
                                        <tr>
                                            <th style="width: 50%;">Activity / Resource</th>
                                            <th>Type</th>
                                            <th class="text-center">Views</th>
                                            <th class="text-center">Status</th>
                                            <th class="text-center">Tracking</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {{#modules}}
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="bg-light rounded p-2 mr-3 text-primary shadow-sm" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                                        <i class="fa {{icon}}"></i>
                                                    </div>
                                                    {{#url}}<a href="{{url}}" target="_blank" class="ca-course-link">{{/url}}
                                                    {{{name}}}
                                                    {{#url}}</a>{{/url}}
                                                </div>
                                            </td>
                                            <td><span class="badge badge-light border px-2 py-1">{{type}}</span></td>
                                            <td class="text-center font-weight-bold">{{views}}</td>
                                            <td class="text-center">
                                                {{#visible}}
                                                    <span class="text-success"><i class="fa fa-check-circle mr-1"></i> Visible</span>
                                                {{/visible}}
                                                {{^visible}}
                                                    <span class="text-muted"><i class="fa fa-eye-slash mr-1"></i> Hidden</span>
                                                {{/visible}}
                                            </td>
                                            <td class="text-center">
                                                {{#completion}}
                                                    <span class="badge badge-info rounded-pill px-3">Completion Tracked</span>
                                                {{/completion}}
                                                {{^completion}}
                                                    <span class="text-muted small">Not Tracked</span>
                                                {{/completion}}
                                            </td>
                                        </tr>
                                        {{/modules}}
                                    </tbody>
                                </table>
                            </div>
                            {{/is_empty}}
                            {{#is_empty}}
                            <div class="p-5 text-center text-muted bg-white">
                                <i class="fa fa-inbox fa-3x mb-3 opacity-25"></i>
                                <p class="mb-0 font-weight-bold">This section is currently empty</p>
                            </div>
                            {{/is_empty}}
                        </div>
                    </div>
                </div>
                {{/sections}}
            </div>
        </div>

        {{! ===== STUDENTS TAB ===== }}
        <div class="tab-pane fade" id="students" role="tabpanel">
            <div class="ca-table-container mx-2">
                <div class="p-4 bg-light border-bottom">
                    <h5 class="mb-0 font-weight-bold" style="color: var(--ca-primary);"><i class="fa fa-user-shield mr-2"></i> Student Performance & Engagement Log</h5>
                </div>
                <div class="table-responsive">
                    <table class="table ca-table table-hover mb-0">
                        <thead class="ca-thead-primary">
                            <tr>
                                <th>Student Identity</th>
                                <th class="text-center">Activity Metrics</th>
                                <th class="text-center">Current Grade</th>
                                <th class="text-center">System Footprint</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#students}}
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-gradient-primary text-white rounded-circle mr-3 d-flex align-items-center justify-content-center shadow-sm" style="width: 45px; height: 45px; font-weight: 800;">
                                            {{#str}}user, core{{/str}}
                                        </div>
                                        <div class="d-flex flex-column">
                                            <span class="font-weight-bold text-dark" style="font-size: 1.1rem;">{{fullname}}</span>
                                            <span class="text-muted small">{{email}}</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex justify-content-center gap-2 flex-wrap">
                                        <span class="badge badge-light border" title="Views">V: {{logins}}</span>
                                        <span class="badge badge-light border" title="Assignments">A: {{assigns}}</span>
                                        <span class="badge badge-light border" title="Quizzes">Q: {{quizzes}}</span>
                                        <span class="badge badge-light border" title="Virtual Sessions">S: {{bbb}}</span>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <div class="ca-pct-badge font-weight-bold px-4 py-2" style="background: var(--ca-background); font-size: 1rem; border: 2px solid rgba(var(--ca-primary), 0.1);">
                                         <span class="text-{{grade_class}}">{{grade}}</span>
                                    </div>
                                </td>
                                <td class="text-center px-4">
                                    <div class="d-flex flex-column align-items-center">
                                        <span class="text-muted small mb-1">Last seen on platform</span>
                                        <span class="badge badge-light border px-3 py-2" style="border-radius: 10px;">{{lastaccess}}</span>
                                    </div>
                                </td>
                            </tr>
                            {{/students}}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    {{! ===== FOOTER ===== }}
    <footer class="text-center text-muted mt-5 py-5 border-top">
        <div style="letter-spacing: 1px; font-weight: 700; font-size: 0.8rem;">
            {{{footer_text}}}
        </div>
    </footer>
</div>

{{#js}}
require(['core/chartjs'], function(Chart) {

    Chart.defaults.font.family = "'Inter', sans-serif";

    var ctxPart = document.getElementById('courseParticipationChart');
    if (ctxPart) {
        new Chart(ctxPart.getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: ['Active Students', 'Inactive Students'],
                datasets: [{
                    data: [{{metrics.active_students}}, {{metrics.inactive_students}}],
                    backgroundColor: ['#2ecc71', '#f39c12'],
                    borderWidth: 0,
                    borderRadius: 15,
                    spacing: 10
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '75%',
                plugins: { 
                    legend: { position: 'bottom', labels: { padding: 30, font: { weight: '800' } } } 
                }
            }
        });
    }
});
{{/js}}
