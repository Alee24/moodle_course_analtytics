<div class="local_courseanalytics_details container-fluid py-3">

    {{! ===== HEADER & NAVIGATION ===== }}
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <h1 class="ca-page-title">
            <i class="fa fa-graduation-cap mr-2 text-primary"></i>
            {{course.shortname}} <span class="text-muted font-weight-light">| {{course.fullname}}</span>
        </h1>
        <div>
            <a href="{{urls.back}}" class="btn btn-outline-secondary btn-lg shadow-sm mr-2">
                <i class="fa fa-arrow-left mr-1"></i> {{#str}} back, local_courseanalytics {{/str}}
            </a>
            <a href="{{urls.export}}" class="btn btn-success btn-lg shadow-sm">
                <i class="fa fa-file-excel-o mr-1"></i> {{#str}} export_excel, local_courseanalytics {{/str}}
            </a>
        </div>
    </div>

    {{! ===== SUMMARY STATS CARDS ===== }}
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card ca-stat-card bg-gradient-primary text-white text-center h-100">
                <div class="card-body d-flex flex-column justify-content-center">
                    <div class="ca-stat-icon"><i class="fa fa-users"></i></div>
                    <div class="ca-stat-value">{{metrics.total_students}}</div>
                    <div class="ca-stat-label">Total Enrolled Users</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card ca-stat-card bg-gradient-success text-white text-center h-100">
                <div class="card-body d-flex flex-column justify-content-center">
                    <div class="ca-stat-icon"><i class="fa fa-line-chart"></i></div>
                    <div class="ca-stat-value">{{metrics.active_students}}</div>
                    <div class="ca-stat-label">Active Users (7 Days)</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card ca-stat-card bg-gradient-info text-white text-center h-100">
                <div class="card-body d-flex flex-column justify-content-center">
                    <div class="ca-stat-icon"><i class="fa fa-trophy"></i></div>
                    <div class="ca-stat-value">{{metrics.completion_rate}}%</div>
                    <div class="ca-stat-label">Avg. Course Completion</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card ca-stat-card bg-gradient-warning text-white text-center h-100">
                <div class="card-body d-flex flex-column justify-content-center">
                    <div class="ca-stat-icon"><i class="fa fa-cubes"></i></div>
                    <div class="ca-stat-value">{{metrics.total_modules}}</div>
                    <div class="ca-stat-label">Total Course Modules</div>
                </div>
            </div>
        </div>
    </div>

    {{! ===== TABS ===== }}
    <ul class="nav nav-pills nav-fill ca-nav-pills mb-4" id="courseAnalyticsTabs" role="tablist">
        <li class="nav-item">
            <a class="nav-link active font-weight-bold shadow-sm" id="content-tab" data-toggle="tab" href="#content" role="tab">
                <i class="fa fa-sitemap mr-1"></i> {{#str}} weekly_breakdown, local_courseanalytics {{/str}}
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link font-weight-bold shadow-sm" id="students-tab" data-toggle="tab" href="#students" role="tab">
                <i class="fa fa-list-ul mr-1"></i> Enrolled Student List
            </a>
        </li>
    </ul>

    <div class="tab-content" id="courseAnalyticsTabsContent">
        {{! ===== CONTENT BREAKDOWN TAB ===== }}
        <div class="tab-pane fade show active" id="content" role="tabpanel">
            <div class="row">
                {{#sections}}
                <div class="col-12 mb-4">
                    <div class="card ca-section-card shadow-sm border-0">
                        <div class="card-header ca-section-header d-flex justify-content-between align-items-center">
                            <h4 class="mb-0 font-weight-bold text-dark">
                                <i class="fa fa-folder-open-o mr-2 text-primary"></i>{{{name}}}
                            </h4>
                            {{#is_empty}}<span class="badge badge-warning text-uppercase px-3 py-2"><i class="fa fa-exclamation-triangle mr-1"></i> Empty</span>{{/is_empty}}
                            {{^is_empty}}<span class="badge badge-primary text-uppercase px-3 py-2"><i class="fa fa-check mr-1"></i> Active</span>{{/is_empty}}
                        </div>
                        <div class="card-body p-0">
                            {{^is_empty}}
                            <div class="table-responsive">
                                <table class="table table-hover ca-module-table mb-0">
                                    <thead class="bg-light">
                                        <tr>
                                            <th class="border-top-0 w-50 pl-4">{{#str}} activityname, local_courseanalytics {{/str}}</th>
                                            <th class="border-top-0">{{#str}} module_type, local_courseanalytics {{/str}}</th>
                                            <th class="border-top-0 text-center">{{#str}} visibility, local_courseanalytics {{/str}}</th>
                                            <th class="border-top-0 text-center">{{#str}} completion_enabled, local_courseanalytics {{/str}}</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {{#modules}}
                                        <tr class="ca-module-row">
                                            <td class="pl-4 align-middle font-weight-bold">
                                                {{#url}}<a href="{{url}}" target="_blank" class="text-decoration-none ca-module-link">{{/url}}
                                                <i class="fa {{icon}} fa-fw mr-2 ca-icon text-muted"></i>
                                                {{{name}}}
                                                {{#url}}</a>{{/url}}
                                            </td>
                                            <td class="align-middle">
                                                <span class="badge badge-light border ca-badge-type">{{type}}</span>
                                            </td>
                                            <td class="align-middle text-center">
                                                {{#visible}}
                                                    <span class="badge badge-success px-2 py-1"><i class="fa fa-eye mr-1"></i>Visible</span>
                                                {{/visible}}
                                                {{^visible}}
                                                    <span class="badge badge-secondary px-2 py-1"><i class="fa fa-eye-slash mr-1"></i>Hidden</span>
                                                {{/visible}}
                                            </td>
                                            <td class="align-middle text-center">
                                                {{#completion}}
                                                    <span class="badge badge-info px-2 py-1"><i class="fa fa-check-circle mr-1"></i>Tracked</span>
                                                {{/completion}}
                                                {{^completion}}
                                                    <span class="text-muted"><i class="fa fa-minus"></i></span>
                                                {{/completion}}
                                            </td>
                                        </tr>
                                        {{/modules}}
                                    </tbody>
                                </table>
                            </div>
                            {{/is_empty}}
                            {{#is_empty}}
                            <div class="p-4 text-center text-muted ca-empty-state">
                                <i class="fa fa-inbox fa-3x mb-3 text-light"></i>
                                <p class="mb-0 font-weight-bold">No modules or activities exist in this section.</p>
                            </div>
                            {{/is_empty}}
                        </div>
                    </div>
                </div>
                {{/sections}}
            </div>
        </div>

        {{! ===== STUDENTS TAB ===== }}
        <div class="tab-pane fade" id="students" role="tabpanel">
            <div class="card ca-card border-0 shadow-sm">
                <div class="card-header ca-card-header">
                    <i class="fa fa-users mr-2"></i> Enrolled Status Log
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover ca-table mb-0">
                            <thead class="ca-thead-secondary">
                                <tr>
                                    <th class="pl-4">Student Name</th>
                                    <th>Email Address</th>
                                    <th class="text-center">{{#str}} lastaccess, local_courseanalytics {{/str}}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#students}}
                                <tr>
                                    <td class="pl-4 font-weight-bold"><i class="fa fa-user-circle-o text-muted mr-2"></i>{{fullname}}</td>
                                    <td><a href="mailto:{{email}}" class="text-muted">{{email}}</a></td>
                                    <td class="text-center"><span class="badge badge-light border">{{lastaccess}}</span></td>
                                </tr>
                                {{/students}}
                                {{^students}}
                                <tr>
                                    <td colspan="3" class="text-center py-4 text-muted">
                                        <i class="fa fa-user-times fa-2x mb-2"></i><br>No students are currently enrolled here.
                                    </td>
                                </tr>
                                {{/students}}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {{! ===== FOOTER ===== }}
    <footer class="text-center text-muted mt-5 py-3 border-top small ca-footer">
        {{{footer_text}}}
    </footer>
</div>
