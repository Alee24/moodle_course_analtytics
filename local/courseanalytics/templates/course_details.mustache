<div class="local_courseanalytics_details container-fluid py-3">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <h1 class="ca-page-title d-flex align-items-center">
            <i class="fa fa-graduation-cap mr-3 text-purple" style="font-size: 2rem; color: #c00085;"></i>
            <span class="font-weight-bold mr-2 text-dark">{{course.shortname}}</span> 
            <span class="text-muted font-weight-light"> | {{course.fullname}}</span>
        </h1>
        <div>
            <a href="{{urls.back}}" class="btn btn-outline-secondary shadow-sm mr-2">
                <i class="fa fa-arrow-left mr-1"></i> [[back]]
            </a>
            <a href="{{urls.export}}" class="btn btn-success shadow-sm" style="background-color: #4caf50; border-color: #4caf50;">
                <i class="fa fa-file-excel-o mr-1"></i> Export to Excel
            </a>
        </div>
    </div>

    {{! ===== SUMMARY STATS CARDS ===== }}
    <div class="row mb-5 justify-content-center">
        <div class="col-md-2 mb-3">
            <div class="card ca-stat-card text-white text-center h-100" style="background-color: #2c6e91;">
                <div class="card-body d-flex flex-column justify-content-center p-4">
                    <div class="ca-stat-icon mb-3"><i class="fa fa-users"></i></div>
                    <div class="ca-stat-value font-weight-bold" style="font-size: 2.8rem;">{{metrics.total_students}}</div>
                    <div class="ca-stat-label mt-2" style="font-size: 0.75rem;">TOTAL ENROLLED USERS</div>
                </div>
            </div>
        </div>
        <div class="col-md-2 mb-3">
            <div class="card ca-stat-card text-white text-center h-100" style="background-color: #2e9f5e;">
                <div class="card-body d-flex flex-column justify-content-center p-4">
                    <div class="ca-stat-icon mb-3"><i class="fa fa-line-chart"></i></div>
                    <div class="ca-stat-value font-weight-bold" style="font-size: 2.8rem;">{{metrics.active_students}}</div>
                    <div class="ca-stat-label mt-2" style="font-size: 0.75rem;">ACTIVE USERS (7 DAYS)</div>
                </div>
            </div>
        </div>
        <div class="col-md-2 mb-3">
            <div class="card ca-stat-card text-white text-center h-100" style="background-color: #17a2b8;">
                <div class="card-body d-flex flex-column justify-content-center p-4">
                    <div class="ca-stat-icon mb-3"><i class="fa fa-trophy"></i></div>
                    <div class="ca-stat-value font-weight-bold" style="font-size: 2.8rem;">{{metrics.completion_rate}}%</div>
                    <div class="ca-stat-label mt-2" style="font-size: 0.75rem;">AVG. COURSE COMPLETION</div>
                </div>
            </div>
        </div>
        <div class="col-md-2 mb-3">
            <div class="card ca-stat-card text-white text-center h-100" style="background-color: #e58e26;">
                <div class="card-body d-flex flex-column justify-content-center p-4">
                    <div class="ca-stat-icon mb-3"><i class="fa fa-cubes"></i></div>
                    <div class="ca-stat-value font-weight-bold" style="font-size: 2.8rem;">{{metrics.total_modules}}</div>
                    <div class="ca-stat-label mt-2" style="font-size: 0.75rem;">TOTAL COURSE MODULES</div>
                </div>
            </div>
        </div>
        <div class="col-md-2 mb-3">
            <div class="card ca-stat-card text-white text-center h-100" style="background-color: #e84393;">
                <div class="card-body d-flex flex-column justify-content-center p-4">
                    <div class="ca-stat-icon mb-3"><i class="fa fa-play-circle-o"></i></div>
                    <div class="ca-stat-value font-weight-bold" style="font-size: 2.8rem;">{{metrics.h5p}}</div>
                    <div class="ca-stat-label mt-2" style="font-size: 0.75rem;">TOTAL H5P CONTENT</div>
                </div>
            </div>
        </div>
    </div>

    {{! ===== TABS ===== }}
    <ul class="nav nav-pills ca-nav-pills mb-4 d-flex justify-content-center pl-0" id="courseAnalyticsTabs" role="tablist">
        <li class="nav-item w-50 max-w-sm">
            <a class="nav-link active font-weight-bold shadow-sm text-center py-2" id="content-tab" data-toggle="tab" href="#content" role="tab" style="border-radius: 8px;">
                <i class="fa fa-sitemap mr-2"></i> Weekly Breakdown
            </a>
        </li>
        <li class="nav-item w-50 max-w-sm">
            <a class="nav-link font-weight-bold shadow-sm text-center py-2" id="students-tab" data-toggle="tab" href="#students" role="tab" style="border-radius: 8px;">
                <i class="fa fa-list-ul mr-2"></i> Enrolled Student List
            </a>
        </li>
    </ul>

    <div class="tab-content border-top pt-4" id="courseAnalyticsTabsContent">
        {{! ===== CONTENT BREAKDOWN TAB ===== }}
        <div class="tab-pane fade show active" id="content" role="tabpanel">
            <div class="row">
                {{#sections}}
                <div class="col-12 mb-4">
                    <div class="card ca-section-card shadow-sm border-0" style="border-radius: 12px; overflow: hidden; background: #fafafa;">
                        <div class="card-header ca-section-header d-flex justify-content-between align-items-center" style="background: transparent; border-bottom: none; padding-top: 1.5rem;">
                            <h4 class="mb-0 font-weight-bold" style="color: #4a4a4a;">
                                <i class="fa fa-folder mr-2" style="color: #c00085;"></i>{{{name}}}
                            </h4>
                            {{#is_empty}}<span class="badge" style="background-color: #f39c12; color: #fff; text-transform: uppercase;"><i class="fa fa-check mr-1"></i> ACTIVE</span>{{/is_empty}}
                            {{^is_empty}}<span class="badge" style="background-color: #c00085; color: #fff; text-transform: uppercase; padding: 5px 15px; border-radius: 4px;"><i class="fa fa-check mr-1"></i> ACTIVE</span>{{/is_empty}}
                        </div>
                        <div class="card-body p-0 mt-2">
                            {{^is_empty}}
                            <div class="table-responsive">
                                <table class="table ca-module-table mb-0 bg-white">
                                    <thead>
                                        <tr style="border-top: 1px solid #dee2e6; border-bottom: 1px solid #dee2e6;">
                                            <th class="border-top-0 w-50 pl-4 text-muted font-weight-bold" style="font-size:0.75rem;">ACTIVITY / RESOURCE NAME</th>
                                            <th class="border-top-0 text-muted font-weight-bold" style="font-size:0.75rem;">TYPE</th>
                                            <th class="border-top-0 text-center text-muted font-weight-bold" style="font-size:0.75rem;">VISIBILITY</th>
                                            <th class="border-top-0 text-center text-muted font-weight-bold" style="font-size:0.75rem;">COMPLETION ENABLED</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {{#modules}}
                                        <tr class="ca-module-row">
                                            <td class="pl-4 align-middle font-weight-bold text-dark" style="font-size: 0.9rem;">
                                                <i class="fa {{icon}} fa-fw mx-2 ca-icon text-muted"></i>
                                                {{#url}}<a href="{{url}}" target="_blank" class="text-decoration-none text-dark">{{/url}}
                                                {{{name}}}
                                                {{#url}}</a>{{/url}}
                                            </td>
                                            <td class="align-middle">
                                                <span class="badge bg-white border border-secondary text-secondary ca-badge-type font-weight-bold px-2 py-1 shadow-sm">{{type}}</span>
                                            </td>
                                            <td class="align-middle text-center">
                                                {{#visible}}
                                                    <span class="badge badge-success px-3 py-1 font-weight-bold shadow-sm" style="border-radius: 12px; background-color: #5cb85c;"><i class="fa fa-eye mr-1"></i>Visible</span>
                                                {{/visible}}
                                                {{^visible}}
                                                    <span class="badge badge-secondary px-3 py-1 shadow-sm" style="border-radius: 12px;"><i class="fa fa-eye-slash mr-1"></i>Hidden</span>
                                                {{/visible}}
                                            </td>
                                            <td class="align-middle text-center">
                                                {{#completion}}
                                                    <span class="badge badge-info px-3 py-1 font-weight-bold shadow-sm" style="border-radius: 12px; background-color: #0275d8;"><i class="fa fa-check-circle mr-1"></i>Tracked</span>
                                                {{/completion}}
                                                {{^completion}}
                                                    <span class="text-muted" style="font-weight: 800; font-size:1.2rem;">&mdash;</span>
                                                {{/completion}}
                                            </td>
                                        </tr>
                                        {{/modules}}
                                    </tbody>
                                </table>
                            </div>
                            {{/is_empty}}
                            {{#is_empty}}
                            <div class="p-4 text-center text-muted ca-empty-state">
                                <i class="fa fa-inbox fa-3x mb-3 text-light"></i>
                                <p class="mb-0 font-weight-bold">No modules or activities exist in this section.</p>
                            </div>
                            {{/is_empty}}
                        </div>
                    </div>
                </div>
                {{/sections}}
            </div>
        </div>

        {{! ===== STUDENTS TAB ===== }}
        <div class="tab-pane fade" id="students" role="tabpanel">
            <div class="card ca-card border-0 shadow-sm">
                <div class="card-header ca-card-header">
                    <i class="fa fa-users mr-2"></i> Enrolled Status Log
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover ca-table mb-0">
                            <thead class="ca-thead-secondary">
                                <tr>
                                    <th class="pl-4">Student Name</th>
                                    <th>Email Address</th>
                                    <th class="text-center">{{#str}} lastaccess, local_courseanalytics {{/str}}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#students}}
                                <tr>
                                    <td class="pl-4 font-weight-bold"><i class="fa fa-user-circle-o text-muted mr-2"></i>{{fullname}}</td>
                                    <td><a href="mailto:{{email}}" class="text-muted">{{email}}</a></td>
                                    <td class="text-center"><span class="badge badge-light border">{{lastaccess}}</span></td>
                                </tr>
                                {{/students}}
                                {{^students}}
                                <tr>
                                    <td colspan="3" class="text-center py-4 text-muted">
                                        <i class="fa fa-user-times fa-2x mb-2"></i><br>No students are currently enrolled here.
                                    </td>
                                </tr>
                                {{/students}}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {{! ===== FOOTER ===== }}
    <footer class="text-center text-muted mt-5 py-3 border-top small ca-footer">
        {{{footer_text}}}
    </footer>
</div>
